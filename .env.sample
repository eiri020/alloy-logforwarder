# Copy this file to .env and adjust the values for your Home Assistant OS host.
#
# HA_DEPLOY_TARGET must include the remote path where local add-ons are stored.
HA_DEPLOY_TARGET=root@homeassistant.local:/addons/alloy-logforwarder/

# HA_SSH_TARGET is only the SSH host used for Home Assistant CLI commands.
HA_SSH_TARGET=root@homeassistant.local

# Optional rollback settings for environments with an unmanaged Alloy fallback.
HA_APP_SLUG=local_alloy_logforwarder
HA_UNMANAGED_ALLOY_CONTAINER=mon-03-05-ha-alloy
